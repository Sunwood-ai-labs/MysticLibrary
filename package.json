{
  "name": "mystic-library",
  "homepage": "https://www.mystic-prompt-library.com/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run docs:dev",
    "build": "npm run docs:build",
    "docs:dev": "vitepress dev docs --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host",
    "docs:canonical-audit": "node script/canonicalize-prompt-catalog.mjs --mode check --json",
    "docs:canonical-sync": "node script/canonicalize-prompt-catalog.mjs --mode sync --write",
    "docs:prompt-mirror-sync": "node script/sync-docs-first-prompts.mjs --write",
    "docs:x-manual-review-merge": "node script/merge-x-manual-review.mjs --write",
    "docs:x-review-overlay": "node script/overlay-x-review-decisions.mjs --write",
    "docs:x-category-promote": "node script/promote-x-categorized-docs.mjs --write",
    "docs:x-category-verify": "node script/verify-x-categorized-docs.mjs --write",
    "docs:x-catalog-sync": "node script/import-x-prompt-archive.mjs --write && node script/promote-x-categorized-docs.mjs --write && node script/verify-x-prompt-archive-docs.mjs --write && node script/verify-x-categorized-docs.mjs --write",
    "preview": "npm run docs:preview",
    "start": "vitepress preview docs --host 0.0.0.0 --port 4173"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vitepress": "^1.6.4"
  }
}
